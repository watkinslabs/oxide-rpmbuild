CFLAGS_FOR_BUILD="-D_GNU_SOURCE -Wno-implicit-function-declaration -Wno-incompatible-pointer-types" \
CFLAGS="-Os -D_GNU_SOURCE -std=gnu89 -Wno-implicit-function-declaration -Wno-incompatible-pointer-types $UAPI" \
