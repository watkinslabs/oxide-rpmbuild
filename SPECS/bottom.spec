rm -rf %{buildroot}
mkdir -p %{buildroot}/usr/bin
install -m0755 target/%{_target_cpu}-unknown-linux-musl/release/btm %{buildroot}/usr/bin/btm
B=target/%{_target_cpu}-unknown-linux-musl/release/build
